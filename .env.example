# Copy to .env and fill in what you need for local release/publishing work.

# Repository coordinates used when rendering the Homebrew cask locally.
REPOSITORY=owner/catpane

# Release version override. Defaults to Cargo.toml if unset.
RELEASE_VERSION=0.1.0

# Homebrew tap publishing.
HOMEBREW_TAP_REPOSITORY=owner/homebrew-tap
HOMEBREW_TAP_TOKEN=
HOMEBREW_TAP_BRANCH=

# Local macOS packaging overrides.
TARGET_TRIPLE=aarch64-apple-darwin
BUNDLE_ID=io.github.owner.catpane
ARCHIVE_ROOT=
ICON_FILE=
PYTHON_BIN=python3

# Manual cask rendering overrides.
ARM64_SHA_FILE=
INTEL_SHA_FILE=
CASK_SOURCE=
