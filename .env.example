# Copy to .env and fill in what you need for local release/publishing work.

# Repository coordinates used when rendering the Homebrew cask locally.
REPOSITORY=owner/catpane

# Release version override. Defaults to Cargo.toml if unset.
RELEASE_VERSION=0.5.3

# Homebrew tap publishing.
HOMEBREW_TAP_REPOSITORY=owner/homebrew-tap
HOMEBREW_TAP_TOKEN=
HOMEBREW_TAP_BRANCH=

# Local macOS packaging overrides.
TARGET_TRIPLE=aarch64-apple-darwin
BUNDLE_ID=io.github.owner.catpane
ARCHIVE_ROOT=
ICON_FILE=
PYTHON_BIN=python3
CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
CODESIGN_ENTITLEMENTS=
APPLE_NOTARY_KEY_ID=
APPLE_NOTARY_ISSUER=
APPLE_NOTARY_KEY_PATH=

# GitHub Actions secrets for signed/notarized macOS releases.
# Store the certificate and App Store Connect API key contents as base64.
APPLE_SIGNING_CERTIFICATE_P12=
APPLE_SIGNING_CERTIFICATE_PASSWORD=
APPLE_KEYCHAIN_PASSWORD=
APPLE_CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
APPLE_NOTARY_API_KEY_P8=

# Manual cask rendering overrides.
ARM64_SHA_FILE=
INTEL_SHA_FILE=
CASK_SOURCE=
